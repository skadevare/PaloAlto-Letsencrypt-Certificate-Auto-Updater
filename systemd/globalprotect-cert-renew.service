[Unit]
Description=Renew GlobalProtect certificate and update Palo Alto
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/YOURPATH/PAN-cerbot
EnvironmentFile=-/YOURPATH/PAN-cerbot/globalprotect-cert-renew.env
ExecStart=/usr/bin/python3 /YOURPATH/PAN-cerbot/renew_globalprotect_cert.py
